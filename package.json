{
  "name": "workflow-repo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "live-server --port=5500",
    "dev": "npx tailwindcss -i ./css/input.css -o ./css/style.css --watch --poll",
    "build": "npx tailwindcss -i ./css/input.css -o ./css/style.css --minify",
    "prepare": "husky install",
    "unit": "vitest",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "e2e:debug": "npx playwright test --debug"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.9",
    "@vitest/browser": "^3.0.7",
    "@vitest/coverage-v8": "^3.0.7",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.5.0",
    "live-server": "^1.2.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.12",
    "vitest": "^3.0.7"
  },
  "lint-staged": {
    "*.{js,css,md,html,json,yml}": "prettier --write",
    "*.js": "eslint --cache --fix"
  }
}
