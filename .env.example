# Example environment variables for testing authentication. 
# Instructions for Use:
# 1: Copy this file and rename it to .env in your project root.
# 2: Replace placeholder values with the real credentials used in testing.
# 3: Add .env to .gitignore to prevent committing sensitive data.
# 4: Delete all comments in the file.

# Test user email (used for login in tests)
TEST_USER_EMAIL=your-email@example.com

# Test user password (used for login in tests)
TEST_USER_PASSWORD=your-secure-password
